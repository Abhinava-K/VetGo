{
	"info": {
		"name": "VetGo API",
		"description": "API collection for VetGo - Uber for Vets",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "User Signup",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\",\n    \"phone\": \"1234567890\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/auth/signup/user" }
					}
				},
				{
					"name": "Doctor Application",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstName\": \"Dr. Jane\",\n    \"lastName\": \"Smith\",\n    \"email\": \"jane@vet.com\",\n    \"password\": \"password123\",\n    \"phone\": \"0987654321\",\n    \"qualifications\": \"MVSc Surgery\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/auth/signup/doctor" }
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/api/auth/login" }
					}
				}
			]
		},
		{
			"name": "Admin",
			"item": [
				{
					"name": "Get Pending Apps",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/api/admin/doctor-applications" }
					}
				},
				{
					"name": "Approve Doctor",
					"request": {
						"method": "POST",
						"header": [],
						"url": { "raw": "{{baseUrl}}/api/admin/doctor-applications/:userId/approve" }
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:4000"
		}
	]
}
